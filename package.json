{
  "name": "opencode-web-sidebar",
  "displayName": "OpenCode Sidebar GUI",
  "description": "OpenCode web-UI in the sidebar panel - connects to your web server or starts a new one, adds narrow UI adaptations, multi-server management...",
  "version": "0.12.0",
  "license": "MIT",
  "publisher": "bmpenuelas",
  "homepage": "https://github.com/bmpenuelas/opencode-web-sidebar",
  "bugs": {
    "email": "bmpenuelas@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bmpenuelas/opencode-web-sidebar.git"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other",
    "Chat"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:opencode-web-sidebar.openPanel",
    "onCommand:opencode-web-sidebar.setPassword",
    "onCommand:opencode-web-sidebar.clearPassword",
    "onCommand:opencode-web-sidebar.startServer",
    "onCommand:opencode-web-sidebar.stopServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "opencode-web-sidebar",
          "title": "OpenCode",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "opencode-web-sidebar": [
        {
          "type": "webview",
          "id": "opencode-web-sidebar.view",
          "name": "OpenCode"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-web-sidebar.openPanel",
        "title": "Toggle OpenCode Panel",
        "category": "OpenCode",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "opencode-web-sidebar.closePanel",
        "title": "Close Panel",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.focusPanel",
        "title": "Focus Panel",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.openFile",
        "title": "Open File",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.setPassword",
        "title": "Set Server Password",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.clearPassword",
        "title": "Clear Server Password",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.startServer",
        "title": "Start OpenCode Web Server",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.stopServer",
        "title": "Stop OpenCode Web Server",
        "category": "OpenCode"
      },
      {
        "command": "opencode-web-sidebar.openSettings",
        "title": "Settings",
        "category": "OpenCode",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opencode-web-sidebar.openPanel",
          "group": "navigation",
          "when": "!config.opencode-web-sidebar.hideButton"
        }
      ],
      "view/title": [
        {
          "command": "opencode-web-sidebar.openSettings",
          "when": "view == opencode-web-sidebar.view",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "opencode-web-sidebar.stopServer",
          "when": "opencode-web-sidebar.startedByUs"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencode-web-sidebar.openPanel",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      }
    ],
    "configuration": {
      "title": "OpenCode Sidebar",
      "properties": {
        "opencode-web-sidebar.url": {
          "type": "string",
          "default": "http://localhost:4096",
          "description": "URL of the OpenCode web UI to embed in the sidebar panel (deprecated: use servers list instead)"
        },
        "opencode-web-sidebar.servers": {
          "type": "array",
          "default": [
            {
              "id": "default",
              "url": "http://localhost:4096",
              "label": "Local Server",
              "isWsl": false,
              "isDefault": true,
              "serverCommand": "opencode web --port 4096"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for this server"
              },
              "url": {
                "type": "string",
                "description": "URL of the server"
              },
              "label": {
                "type": "string",
                "description": "Display label for the server"
              },
              "isWsl": {
                "type": "boolean",
                "description": "Translate workspace paths for WSL/Linux"
              },
              "isDefault": {
                "type": "boolean",
                "description": "Whether this is the default server"
              },
              "serverCommand": {
                "type": "string",
                "description": "Command to start the server locally"
              },
              "username": {
                "type": "string",
                "description": "Username for authentication"
              },
              "authEnabled": {
                "type": "boolean",
                "description": "Enable authentication fields"
              }
            },
            "required": [
              "id",
              "url"
            ]
          },
          "description": "List of configured OpenCode servers"
        },
        "opencode-web-sidebar.hideButton": {
          "type": "boolean",
          "default": false,
          "description": "Hide the OpenCode button from the editor title bar"
        },
        "opencode-web-sidebar.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically attempt to reconnect when the server is unreachable"
        },
        "opencode-web-sidebar.maxReconnectAttempts": {
          "type": "number",
          "default": 0,
          "description": "Maximum number of reconnection attempts (0 = unlimited)"
        },
        "opencode-web-sidebar.serverCommand": {
          "type": "string",
          "default": "opencode web --port 4096",
          "description": "Command to start the OpenCode web server (deprecated: use per-server serverCommand instead)"
        },
        "opencode-web-sidebar.workspacePathStyle": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "wsl"
          ],
          "enumItemLabels": [
            "Do not translate",
            "WSL / Linux"
          ],
          "description": "Path translation mode (deprecated: use per-server isWsl instead)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test",
    "publish:marketplace": "vsce package && vsce publish",
    "publish:openvsx": "bash -c \"read -p 'Enter packaged filename: ' filename && read -sp 'Enter openvsx token: ' token && echo && npx ovsx publish \\\"$filename\\\" -p \\\"$token\\\"\"",
    "publish": "npm version minor --no-git-tag-version && npm run publish:marketplace && npm run publish:openvsx"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.106.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
